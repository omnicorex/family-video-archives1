<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 44 44" fill="none">
  <!-- Film frame body -->
  <rect x="5" y="11" width="34" height="24" rx="2.5" stroke="#EEEAF4" stroke-width="1.5"/>
  <!-- Armenian tricolor left edge -->
  <rect x="5" y="11"   width="5" height="8"  rx="1.5" fill="#C8001A"/>
  <rect x="5" y="19"   width="5" height="8"  rx="0"   fill="#002FA0"/>
  <rect x="5" y="27"   width="5" height="8"  rx="1.5" fill="#D88000"/>
  <!-- Film sprocket holes — top -->
  <rect x="11" y="7"  width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <rect x="20" y="7"  width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <rect x="29" y="7"  width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <!-- Film sprocket holes — bottom -->
  <rect x="11" y="35" width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <rect x="20" y="35" width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <rect x="29" y="35" width="5" height="4" rx="1" fill="#EEEAF4" opacity="0.35"/>
  <!-- Play triangle -->
  <path d="M19 18.5 L19 27.5 L27 23 Z" fill="#EEEAF4" opacity="0.85"/>
</svg>
